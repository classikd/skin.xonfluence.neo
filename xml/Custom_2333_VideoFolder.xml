<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="2333">
    <defaultcontrol always="true">9000</defaultcontrol>
    <coordinates>
        <left>30</left>
        <top>45</top>
    </coordinates>
    <include>dialogeffect</include>
    <controls>
        <control type="group">
            <control type="image">
                <description>background image</description>
                <left>0</left>
                <top>0</top>
                <width>720</width>
                <height>990</height>
                <texture border="40">DialogBack.png</texture>
            </control>
            <control type="image">
                <description>Dialog Header image</description>
                <left>0</left>
                <top>0</top>
                <width>720</width>
                <height>70</height>
                <texture>dialogheader.png</texture>
            </control>
            <control type="label">
                <description>header label</description>
                <left>30</left>
                <top>8</top>
                <width>610</width>
                <height>60</height>
                <font>font12_title</font>
                <label>$LOCALIZE[31779]</label>
                <align>center</align>
                <aligny>center</aligny>
                <textcolor>white</textcolor>
                <shadowcolor>black</shadowcolor>
            </control>
            <control type="button" id="57">
                <description>Close Window button</description>
                <left>650</left>
                <top>0</top>
                <onclick>PreviousMenu</onclick>
                <include>DialogCloseButton</include>
            </control>
                        
            <control type="list" id="9000">
                <left>30</left>
                <top>110</top>
                <width>620</width>
                <height>850</height>
                <onup>9000</onup>
                <ondown>9000</ondown>
                <onleft>60</onleft>
                <onright>60</onright>
                <pagecontrol>60</pagecontrol>
                <scrolltime>200</scrolltime>
                <content target="video">$INFO[Player.FolderPath]</content>
                <onclick>PlayMedia($INFO[Player.FolderPath],isdir,playoffset=$INFO[Container(9000).CurrentItem])</onclick>
                <onclick condition="Player.HasAudio">ActivateWindow(Visualisation)</onclick>
                <itemlayout height="120">
                    <control type="image">
                        <left>0</left>
                        <top>100</top>
                        <width>620</width>
                        <height>20</height>
                        <texture border="0,1,0,1">MenuItemNF-bottom.png</texture>
                    </control>
                    <control type="image">
                        <left>15</left>
                        <top>15</top>
                        <width>130</width>
                        <height>90</height>
                        <texture background="true" fallback="DefaultVideoCover.png" colordiffuse="$VAR[DiffuseIfNoPosterThumb]">$VAR[PosterThumb]</texture>
                        <aspectratio>scale</aspectratio>
                    </control>
                    <control type="label">
                        <left>165</left>
                        <top>25</top>
                        <width>450</width>
                        <height>60</height>
                        <font>font13</font>
                        <label>$INFO[ListItem.Label]</label>
                        <textcolor>white</textcolor>
                        <selectedcolor>$VAR[MainColorOne]</selectedcolor>
                        <align>left</align>
                        <aligny>center</aligny>
                    </control>
                </itemlayout>
                <focusedlayout height="120">

                    <control type="image">
                        <left>0</left>
                        <top>100</top>
                        <width>620</width>
                        <height>20</height>
                        <texture border="0,1,0,1">MenuItemNF-bottom.png</texture>
                        <visible>!Control.HasFocus(9000)</visible>
                    </control>

                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>830</width>
                        <height>120</height>
                        <texture border="0,2,0,2" colordiffuse="$VAR[MainColorOne]">white.png</texture>
                        <visible>Control.HasFocus(9000)</visible>
                    </control>

                    <control type="image">
                        <left>15</left>
                        <top>15</top>
                        <width>130</width>
                        <height>90</height>
                        <texture background="true" fallback="DefaultVideoCover.png" colordiffuse="$VAR[DiffuseIfNoPosterThumb]">$VAR[PosterThumb]</texture>
                        <aspectratio>scale</aspectratio>
                    </control>

                    <control type="label">
                        <left>165</left>
                        <top>25</top>
                        <width>450</width>
                        <height>60</height>
                        <font>font13</font>
                        <label>$INFO[ListItem.Label]</label>
                        <textcolor>white</textcolor>
                        <selectedcolor>white</selectedcolor>
                        <align>left</align>
                        <aligny>center</aligny>
                        <visible>!Control.HasFocus(9000)</visible>
                    </control>
                    <control type="label">
                        <left>165</left>
                        <top>25</top>
                        <width>450</width>
                        <height>60</height>
                        <font>font13</font>
                        <label>$INFO[ListItem.Label]</label>
                        <textcolor>black</textcolor>
                        <selectedcolor>black</selectedcolor>
                        <align>left</align>
                        <aligny>center</aligny>
                        <visible>Control.HasFocus(9000)</visible>
                    </control>
                </focusedlayout>
            </control>
     
            <control type="scrollbar" id="60">
                <left>665</left>
                <top>105</top>
                <width>38</width>
                <height>850</height>
                <texturesliderbackground border="0,14,0,14">ScrollBarV.png</texturesliderbackground>
                <texturesliderbar border="0,14,0,14">ScrollBarV_bar.png</texturesliderbar>
                <texturesliderbarfocus border="0,14,0,14" colordiffuse="$VAR[MainColorOne]">ScrollBarV_bar_focus.png</texturesliderbarfocus>
                <textureslidernib colordiffuse="$VAR[MainColorOne]">ScrollBarNib.png</textureslidernib>
                <textureslidernibfocus colordiffuse="$VAR[MainColorOne]">ScrollBarNib.png</textureslidernibfocus>
                <onleft>9000</onleft>
                <onright>9000</onright>
                <ondown>61</ondown>
                <onup>61</onup>
                <showonepage>false</showonepage>
                <orientation>vertical</orientation>
            </control>
 
        </control>
    </controls>
</window>
